class Shields < Formula
  desc "Claude Code security hook - command guard + file ACL"
  homepage "https://github.com/thkt/shields"
  version "__VERSION__"
  license "MIT"

  on_macos do
    on_arm do
      url "https://github.com/thkt/shields/releases/download/__TAG__/shields-aarch64-apple-darwin.tar.gz"
      sha256 "__SHA_AARCH64_DARWIN__"
    end
    on_intel do
      url "https://github.com/thkt/shields/releases/download/__TAG__/shields-x86_64-apple-darwin.tar.gz"
      sha256 "__SHA_X86_64_DARWIN__"
    end
  end

  on_linux do
    on_arm do
      url "https://github.com/thkt/shields/releases/download/__TAG__/shields-aarch64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_AARCH64_LINUX__"
    end
    on_intel do
      url "https://github.com/thkt/shields/releases/download/__TAG__/shields-x86_64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_X86_64_LINUX__"
    end
  end

  def install
    bin.install "shields"
  end

  def caveats
    <<~EOS
      shields provides two Claude Code hooks:

        shields check  — PreToolUse Bash guard (command patterns + secrets)
        shields acl    — PermissionRequest file ACL

      Configure per-project in .claude/tools.json:

        {
          "shields": {
            "check": true,
            "acl": true,
            "custom_patterns": [],
            "safe_dirs": [],
            "deny_subagent": []
          }
        }
    EOS
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/shields --version")
  end
end
